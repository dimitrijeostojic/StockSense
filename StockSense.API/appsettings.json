{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "$(ConnectionStrings.DefaultConnection)",
    "AuthConnection": "$(ConnectionStrings.AuthConnection)"
  },
  "RabbitMQ": {
    "Host": "$(RabbitMQ.Host)",
    "Username": "$(RabbitMQ.Username)",
    "Password": "$(RabbitMQ.Password)"
  },
  "Redis": {
    "ConnectionString": "$(Redis.ConnectionString)"
  },
  "Jwt": {
    "SecretKey": "$(Jwt.SecretKey)",
    "Issuer": "$(Jwt.Issuer)",
    "Audience": "$(Jwt.Audience)",
    "ExpirationInMinutes": "$(Jwt.ExpirationInMinutes)"
  },
  "AllowedHosts": "*"
}
